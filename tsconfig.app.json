{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,                  // ← important: allows .js/.jsx files
    "checkJs": false,                 // optional: set true if you want type checking on JS
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "types": ["vite/client"]
  },
  "include": ["src", "postcss.config.js"]
}